generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum ContactType {
  LEAD
  CLIENT
}

enum ContactMethod {
  PHONE
  WHATSAPP
  EMAIL
  IN_PERSON
  NONE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
}

enum SaleType {
  REGULAR
  CONSIGNMENT
}

enum SaleStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum ProductCategory {
  AUTOMOTIVE
  ARCHITECTURAL
  PPF
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(OPERATOR)
  avatarUrl     String?   @db.LongText
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedLeads   Contact[]      @relation("AssignedTo")
  scheduledVisits Visit[]        @relation("VisitAssignedTo")
  createdVisits   Visit[]        @relation("VisitCreatedBy")
  scheduledCalls  Call[]         @relation("CallAssignedTo")
  createdCalls    Call[]         @relation("CallCreatedBy")
  sales           Sale[]
  quotes          Quote[]
  assignedUnits   ProductUnit[]  @relation("UnitAssignedTo")
  notifications   Notification[]

  @@map("users")
}

model CrmTask {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  priority  String?   // LOW | MEDIUM | HIGH
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("crm_tasks")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#6366f1")
  createdAt DateTime     @default(now())

  contacts  ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Contact {
  id              String        @id @default(cuid())
  type            ContactType   @default(LEAD)
  firstName       String
  lastName        String
  company         String?
  sector          String?       // AUTOMOTRIZ | ARQUITECTURA | SOFTWARE
  email           String?
  phone           String?
  whatsapp        String?
  address         String?
  city            String?
  state           String?
  notes           String?       @db.Text

  // Lead-specific fields
  contacted       Boolean       @default(false)
  contactMethod   ContactMethod @default(NONE)
  contactDate     DateTime?
  vehicleFlowWeekly    Int?
  architecturalFlowMonthly Int?
  currentSupplier      String?
  currentSupplierPrices String? @db.Text
  avatarUrl       String?       @db.LongText

  assignedToId    String?
  assignedTo      User?         @relation("AssignedTo", fields: [assignedToId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tags            ContactTag[]
  visits          Visit[]
  calls           Call[]
  quotes          Quote[]
  sales           Sale[]
  payments        Payment[]

  @@map("contacts")
}

model Visit {
  id            String    @id @default(cuid())
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedToId  String
  assignedTo    User      @relation("VisitAssignedTo", fields: [assignedToId], references: [id])
  createdById   String
  createdBy     User      @relation("VisitCreatedBy", fields: [createdById], references: [id])
  scheduledDate DateTime
  notes         String?   @db.Text
  completed     Boolean   @default(false)
  completedDate DateTime?
  result        String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("visits")
}

model Call {
  id           String    @id @default(cuid())
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User      @relation("CallAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User      @relation("CallCreatedBy", fields: [createdById], references: [id])
  scheduledAt  DateTime
  durationMin  Int?
  notes        String?   @db.Text
  completed    Boolean   @default(false)
  completedAt  DateTime?
  result       String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("calls")
}

model Product {
  id            String          @id @default(cuid())
  name          String
  description   String?         @db.Text
  category      ProductCategory
  subcategory   String?         // PREMIUM | NANOCERAMIC | NANOCARBON | SAFETY | PPF (for AUTOMOTIVE)
  brand         String?
  width         Decimal?        @db.Decimal(10, 2)
  length        Decimal?        @db.Decimal(10, 2)
  shade         String?         // e.g., "05", "20", "35" or manual for PPF
  price         Decimal         @db.Decimal(10, 2)
  cost          Decimal?        @db.Decimal(10, 2)
  stock         Int             @default(0)
  minStock      Int             @default(0)
  sku           String?         @unique
  imageUrl      String?         @db.LongText // base64 or URL
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  quoteItems    QuoteItem[]
  saleItems     SaleItem[]
  discounts     ProductDiscount[]
  units         ProductUnit[]

  @@map("products")
}

model ProductDiscount {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   // FIXED | PERCENTAGE
  value     Decimal  @db.Decimal(10, 2)
  label     String?
  createdAt DateTime @default(now())

  @@map("product_discounts")
}

model ProductUnit {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  code         String    @unique // [CAT_ABBREV]-[SHADE]-[SEQ4]
  assignedToId String?
  assignedTo   User?     @relation("UnitAssignedTo", fields: [assignedToId], references: [id])
  assignedAt   DateTime?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("product_units")
}

model QuoteItem {
  id            String    @id @default(cuid())
  quoteId       String
  quote         Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Decimal   @db.Decimal(10, 2)
  discount      Decimal   @default(0) @db.Decimal(10, 2)
  discountType  String    @default("FIXED") @db.VarChar(10)
  total         Decimal   @db.Decimal(10, 2)

  @@map("quote_items")
}

model Quote {
  id            String        @id @default(cuid())
  number        Int           @unique @default(autoincrement())
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  status        QuoteStatus   @default(DRAFT)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  requiresFactura Boolean       @default(false)
  validUntil    DateTime?
  notes         String?       @db.Text
  convertedToSaleId String?
  sentAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         QuoteItem[]

  @@map("quotes")
}

model Sale {
  id            String        @id @default(cuid())
  number        Int           @unique @default(autoincrement())
  contactId     String
  contact       Contact       @relation(fields: [contactId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  requiresFactura Boolean       @default(false)
  type          SaleType      @default(REGULAR)
  status        SaleStatus    @default(PENDING)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         SaleItem[]
  remito        Remito?
  payments      Payment[]

  @@map("sales")
}

model SaleItem {
  id          String    @id @default(cuid())
  saleId      String
  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(10, 2)

  @@map("sale_items")
}

model Remito {
  id          String    @id @default(cuid())
  number      Int       @unique @default(autoincrement())
  saleId      String    @unique
  sale        Sale      @relation(fields: [saleId], references: [id])
  issuedAt    DateTime  @default(now())
  notes       String?   @db.Text
  facturaInfo String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("remitos")
}

model Payment {
  id          String        @id @default(cuid())
  saleId      String
  sale        Sale          @relation(fields: [saleId], references: [id])
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id])
  amount      Decimal       @db.Decimal(10, 2)
  method      String?
  reference   String?
  notes       String?       @db.Text
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("payments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // VISIT_ASSIGNED | CALL_ASSIGNED
  title     String
  message   String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Competitor {
  id            String    @id @default(cuid())
  name          String
  website       String?
  phone         String?
  email         String?
  address       String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products      CompetitorProduct[]

  @@map("competitors")
}

model CompetitorProduct {
  id            String    @id @default(cuid())
  competitorId  String
  competitor    Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  name          String
  category      ProductCategory
  brand         String?
  shade         String?
  price         Decimal   @db.Decimal(10, 2)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("competitor_products")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}
